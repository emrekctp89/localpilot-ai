GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Test modu: sk_test_ + test kart 4242 4242 4242 4242 (gerçek kart gerekmez)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Yerel webhook için: stripe listen --forward-to localhost:8000/stripe-webhook
# CLI'nin verdiği whsec_ değerini STRIPE_WEBHOOK_SECRET olarak kullanın

FRONTEND_URL=http://localhost:3000
# Stripe dönüş URL'si — frontend'i hangi adreste açıyorsan onu yaz (127.0.0.1 değil localhost)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional: wildcard origins become regex (e.g. https://app-*.vercel.app)
# ALLOW_ORIGIN_REGEX=https://.*\.vercel\.app
# CORS_ALLOW_VERCEL_PREVIEWS=true

# Optional shared key for scripts; production also accepts Supabase JWT.
AI_SERVICE_API_KEY=
AI_SERVICE_REQUIRE_AUTH=false
ENVIRONMENT=development
RATE_LIMIT_PER_MINUTE=60

# Faz E — WhatsApp Cloud API
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_GRAPH_API_VERSION=v21.0

# Faz E — Google Business Profile OAuth
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/integration/google/oauth/callback